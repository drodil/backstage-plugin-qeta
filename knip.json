{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "{plugins}/*/{fixtures,templates,migrations}/**",
    "node_modules/**"
  ],
  "workspaces": {
    "plugins/*": {
      "entry": [
        "src/index.{ts,tsx}",
        "src/routes.ts",
        "dev/index.{ts,tsx}",
        "src/run.ts"
      ],
      "jest": {
        "entry": ["src/setupTests.ts", "**/*.test.{ts,tsx}"]
      },
      "ignore": [".eslintrc.js", "knexfile.js"]
    }
  },
  "ignoreDependencies": [
    "react",
    "react-dom",
    "react-router",
    "react-router-dom",
    "commander",
    "@backstage/types"
  ]
}
