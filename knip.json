{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "{plugins}/*/{fixtures,templates,migrations}/**",
    "node_modules/**"
  ],
  "workspaces": {
    "plugins/*": {
      "entry": ["src/index.{ts,tsx}"],
      "jest": {
        "entry": ["src/setupTests.ts", "**/*.test.{ts,tsx}"]
      },
      "ignore": [".eslintrc.js", "knexfile.js"]
    },
    "plugins/qeta": {
      "entry": ["configSchema.d.ts", "dev/index.tsx"],
      "jest": {
        "entry": ["src/setupTests.ts", "**/*.test.{ts,tsx}"]
      },
      "ignore": [".eslintrc.js", "knexfile.js"]
    },
    "plugins/qeta-backend": {
      "entry": ["configSchema.d.ts", "dev/index.ts"],
      "jest": {
        "entry": ["src/setupTests.ts", "**/*.test.{ts,tsx}"]
      },
      "ignore": [".eslintrc.js", "knexfile.js"]
    },
    "plugins/qeta-backend-module-openai": {
      "entry": ["configSchema.d.ts"],
      "jest": {
        "entry": ["src/setupTests.ts", "**/*.test.{ts,tsx}"]
      },
      "ignore": [".eslintrc.js", "knexfile.js"]
    },
    "plugins/search-backend-module-qeta": {
      "entry": ["configSchema.d.ts"],
      "jest": {
        "entry": ["src/setupTests.ts", "**/*.test.{ts,tsx}"]
      },
      "ignore": [".eslintrc.js", "knexfile.js"]
    }
  },
  "ignoreDependencies": [
    "react",
    "react-dom",
    "react-router",
    "react-router-dom",
    "commander"
  ]
}
